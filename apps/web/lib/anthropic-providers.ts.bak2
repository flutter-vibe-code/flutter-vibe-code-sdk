      { id: 'deepseek-v4-pro[1m]', name: 'DeepSeek V4 Pro (1M)', description: 'Long-context flagship', isDefault: true },
      { id: 'deepseek-v4-flash', name: 'DeepSeek V4 Flash', description: 'Faster + cheaper, used for subagents' },
