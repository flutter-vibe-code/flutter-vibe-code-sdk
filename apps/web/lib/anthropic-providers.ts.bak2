/**
 * Catalog of Anthropic-compatible providers for the Claude Agent SDK.
 *
 * The SDK reads these env vars (verified by inspecting cli.js):
 *   - ANTHROPIC_API_KEY
 *   - ANTHROPIC_AUTH_TOKEN
 *   - ANTHROPIC_BASE_URL
 *   - ANTHROPIC_MODEL                 (primary model the SDK uses)
 *   - ANTHROPIC_DEFAULT_OPUS_MODEL    (what the SDK calls when "opus" is requested internally)
 *   - ANTHROPIC_DEFAULT_SONNET_MODEL
 *   - ANTHROPIC_DEFAULT_HAIKU_MODEL   (typically a faster/cheaper variant — used for subagents)
 *   - CLAUDE_CODE_SUBAGENT_MODEL      (overrides the model used by SDK-spawned subagents)
 *   - CLAUDE_CODE_EFFORT_LEVEL        ("min" | "low" | "medium" | "high" | "max")
 *
 * By switching these env vars per request we can route the same SDK to any
 * provider that exposes an Anthropic Messages API.
 *
 * Verified Anthropic-compat endpoints:
 *   - anthropic   (native, no override)
 *   - deepseek    https://api.deepseek.com/anthropic        (config provided by DeepSeek)
 *   - minimax     https://api.minimax.io/anthropic          (config provided by MiniMax)
 *   - moonshot    https://api.moonshot.ai/anthropic         (Kimi K2)
 *
 * Providers that need an external translator (deferred — not in this catalog):
 *   - openrouter  (no Anthropic-compat endpoint at the time of writing)
 *   - opencode-go (OpenAI-compat only — needs cc-go-oc proxy)
 */

export type ProviderId = 'anthropic' | 'deepseek' | 'minimax' | 'moonshot'

export interface ProviderModel {
  id: string
  name: string
  description?: string
  isDefault?: boolean
}

export interface AnthropicCompatProvider {
  id: ProviderId
  name: string
  /** Override for ANTHROPIC_BASE_URL. Undefined means use the SDK default (api.anthropic.com). */
  baseURL?: string
  /** Name of the env var on the Next process that holds the server-side fallback key. */
  apiKeyEnv: string
  /** Some providers require both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN to be set to the same value. */
  requiresAuthToken: boolean
  /** Maps to ANTHROPIC_MODEL — the primary model the SDK uses. Undefined = SDK default. */
  primaryModel?: string
  /** Maps to ANTHROPIC_DEFAULT_OPUS_MODEL — what the SDK calls when "opus" is requested internally. */
  opusModel?: string
  /** Maps to ANTHROPIC_DEFAULT_SONNET_MODEL */
  sonnetModel?: string
  /** Maps to ANTHROPIC_DEFAULT_HAIKU_MODEL — typically a faster/cheaper variant. */
  haikuModel?: string
  /** Maps to CLAUDE_CODE_SUBAGENT_MODEL — typically same as haikuModel. */
  subagentModel?: string
  /** Maps to CLAUDE_CODE_EFFORT_LEVEL — "min"|"low"|"medium"|"high"|"max". */
  effortLevel?: 'min' | 'low' | 'medium' | 'high' | 'max'
  models: ProviderModel[]
  defaultModel: string
}

