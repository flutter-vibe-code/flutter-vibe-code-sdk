    apiKeyEnv: 'MINIMAX_API_KEY',
    requiresAuthToken: true,
    primaryModel: 'MiniMax-M2',
    opusModel: 'MiniMax-M2',
    sonnetModel: 'MiniMax-M2',
    haikuModel: 'MiniMax-M2',
    subagentModel: 'MiniMax-M2',
    effortLevel: 'max',
    models: [
      { id: 'MiniMax-M2', name: 'MiniMax M2', description: 'Latest MiniMax flagship', isDefault: true },
